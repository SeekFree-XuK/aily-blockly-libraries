  "keywords": [
    "aily",
    "blockly",
    "rtc",
    "ds3231",
    "ds1307",
    "ds1302",
    "pcf8563",
    "clock",
    "time",
    "datetime",
    "i2c",
    "temperature"
  ],
  "author": "Michael C. Miller (Makuna)",
  "license": "LGPL-3.0",
  "compatibility": {
    "core": [
      "arduino:avr",
      "arduino:megaavr",
      "arduino:samd",
      "esp32:esp32",
      "esp8266:esp8266",
      "rp2040:rp2040"
    ],
    "voltage": [3.3, 5]
  },
  "tested": false,
  "tester": "",
  "url": "https://github.com/Makuna/Rtc",
  "repository": {
    "type": "git",
    "url": "https://github.com/Makuna/Rtc.git"
  }
